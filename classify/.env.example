# Supabase — https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
AUTH_SESSION_SECRET=replace-with-a-long-random-secret
GOD_MODE_SECRET=replace-with-your-private-admin-secret

# World ID — https://developer.worldcoin.org → New App → Actions
# Create an action named "classify-verify" in the World ID developer portal
NEXT_PUBLIC_WLD_APP_ID=app_staging_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_WLD_ACTION=classify-verify
WLD_RP_ID=rp_xxxxxxxxxxxxxxxx
WLD_RP_SIGNING_KEY=0xyour_world_id_signing_key
DEV_PORTAL_API_KEY=your_world_dev_portal_api_key

# World wallet funding + payouts
# The treasury private key receives task funding and sends worker payouts.
WORLD_TREASURY_PRIVATE_KEY=0xyour_worldchain_treasury_private_key
WORLD_WLD_TOKEN_ADDRESS=0xyour_wld_token_contract_on_worldchain
# Optional: defaults to viem's World Chain public RPC if omitted
# WORLDCHAIN_RPC_URL=https://worldchain-mainnet.g.alchemy.com/public

# ── Judge model ────────────────────────────────────────────────────────────────
# Recommended for Vercel / online deployments via Groq
AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b

# Alternative hosted provider
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Optional local development setup via any OpenAI-compatible server
# AI_PROVIDER=openai_compatible
# OPENAI_COMPATIBLE_BASE_URL=http://127.0.0.1:11434/v1
# OPENAI_COMPATIBLE_MODEL=classify-judge
# OPENAI_COMPATIBLE_API_KEY=                # only needed if your server requires auth

# Legacy env names still supported:
# LOCAL_LLM_BASE_URL=http://127.0.0.1:11434/v1
# LOCAL_LLM_MODEL=classify-judge
# LOCAL_LLM_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
